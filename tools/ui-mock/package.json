{
  "name": "ui-mock",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:internal-beta": "tsc -b && vite build --mode internal-beta && node --import tsx scripts/assertInternalBetaBuild.ts",
    "build:demo": "tsc -b && vite build --mode development-demo",
    "api": "tsx server/scannerApiServer.ts",
    "server:product": "tsx server/productVpsServer.ts",
    "test:contract": "node --import tsx tests/contract.test.ts && node --import tsx --test tests/realDataBoundary.test.ts tests/automationStatus.test.ts tests/controlCenter.test.ts tests/ownerOperations.test.ts && node --import tsx --test tests/productRadar.test.ts",
    "test:runtime": "node --import tsx --test tests/productionRuntime.test.ts tests/runtimeImportBoundary.test.ts tests/automationStatus.test.ts tests/controlCenter.test.ts tests/ownerOperations.test.ts",
    "test:product-radar": "node --import tsx --test tests/productRadar.test.ts",
    "test:control-center": "node --import tsx --test tests/controlCenter.test.ts",
    "test:reports": "node --import tsx --test tests/reportsLibrary.test.ts",
    "test:owner-operations": "node --import tsx --test tests/ownerOperations.test.ts",
    "test:established-promotion": "node --import tsx --test tests/establishedPromotion.test.ts tests/establishedPromotionUi.test.tsx",
    "test:feedback": "node --import tsx --test tests/persistentFeedback.test.ts tests/persistentFeedbackUi.test.tsx",
    "test:boundary": "node --import tsx --test tests/realDataBoundary.test.ts",
    "workflow:smoke": "tsx scripts/localWorkflowSmoke.ts",
    "report:analyst": "tsx scripts/generateAnalystReport.ts",
    "report:analyst:smoke": "tsx scripts/generateAnalystReport.ts --smoke",
    "dev:with-api": "concurrently \"vite --host 0.0.0.0\" \"tsx server/scannerApiServer.ts\"",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^9.2.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
