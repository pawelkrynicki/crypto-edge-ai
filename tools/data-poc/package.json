{
  "name": "@crypto-edge-ai/data-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "poc:fixture": "tsc && node dist/src/runDexScreenerPoc.js --mode fixture",
    "poc:live": "tsc && node dist/src/runDexScreenerPoc.js --mode live",
    "security:fixture": "tsc && node dist/src/runSecurityPoc.js --mode fixture",
    "security:live": "tsc && node dist/src/runSecurityPoc.js --mode live",
    "poc:fixture:security": "tsc && node dist/src/runSecurityPoc.js --mode fixture --candidate-from-dex-fixture true",
    "scanner:fixture": "tsc && node dist/src/runCombinedScannerPoc.js --mode fixture",
    "scanner:live": "tsc && node dist/src/runCombinedScannerPoc.js --mode live",
    "scanner:persist:fixture": "tsc && node dist/src/runPersistableScannerPoc.js --mode fixture",
    "scanner:persist:live": "tsc && node dist/src/runPersistableScannerPoc.js --mode live",
    "scanner:validate": "tsc && node dist/src/runStorageValidationPoc.js",
    "scanner:validate:fixture": "tsc && node dist/src/runStorageValidationPoc.js --mode fixture",
    "scanner:import:dry-run": "tsc && node dist/src/runDbImportDryRunPoc.js",
    "scanner:import:dry-run:fixture": "tsc && node dist/src/runDbImportDryRunPoc.js --mode fixture",
    "scanner:import:dry-run:live": "tsc && node dist/src/runDbImportDryRunPoc.js --mode live",
    "sources:validate": "tsc && node dist/src/runSourceRegistryValidation.js",
    "sources:check": "tsc && node dist/src/runSourcePolicyCheck.js",
    "sources:approved:fixture": "tsc && node dist/src/sources/runApprovedSourcesPoc.js --mode fixture",
    "sources:approved:live": "tsc && node dist/src/sources/runApprovedSourcesPoc.js --mode live",
    "collect:internal-beta": "tsc && node dist/src/runInternalBetaCollector.js",
    "discovery:diagnostic": "tsc && node dist/src/runDiscoveryDiagnostic.js",
    "discovery:prototype": "tsc && node dist/src/runEstablishedDiscoveryPrototype.js",
    "discovery:established:validate": "tsc && node dist/src/runEstablishedDiscoveryPrototype.js",
    "filters:calibrate": "tsc && node dist/src/runFilterCalibration.js",
    "snapshot:validate:latest": "tsc && node dist/src/runValidateLatestSnapshot.js",
    "test": "tsc && node --test dist/tests/*.js",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "typescript": "^5.7.2"
  }
}
